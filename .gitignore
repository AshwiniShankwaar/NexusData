# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ---- Claude ----
.claude/

# ── Build / distribution ───────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/

# ── Testing ────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
*.log
test_out.log

# ── NexusData runtime data ─────────────────────────────────────────────────────
config.json          # contains API keys — NEVER commit
nexus_kb/            # per-DB knowledge bases (large, auto-generated)
nexus_exports/       # CSV / JSON exports
data/                # app-generated exports and uploads

# ── Logs ────────────────────────────────────────────────────────────────────────
logs/nexus_*.log     # daily log files (auto-generated)
logs/archive/        # weekly zip archives
!logs/.gitkeep
!logs/archive/.gitkeep
logs/
# ── Databases (local dev samples only) ────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── IDE / OS ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Type checkers / linters ────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
pyrightconfig.json
