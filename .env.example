# NexusData Environment Configuration — Example
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is tracked.

# ── Application Secret ────────────────────────────────────────────────────────
# Auto-generated on first boot. You can also set it manually:
#   python -c "import secrets; print(secrets.token_hex(32))"
NEXUS_SECRET_KEY=change-me-to-a-random-secret

# ── LLM Configuration ─────────────────────────────────────────────────────────
# Updated automatically by /change-model command.
NEXUS_LLM_API_KEY=
NEXUS_LLM_PROVIDER=
NEXUS_LLM_MODEL=

# ── Database — Full URI (takes priority over components below) ────────────────
NEXUS_DB_URI=

# ── Database — Individual Components (updated by /change-db) ─────────────────
NEXUS_DB_DRIVER=postgresql+psycopg2
NEXUS_DB_HOST=localhost
NEXUS_DB_PORT=5432
NEXUS_DB_NAME=
NEXUS_DB_USER=
NEXUS_DB_PASSWORD=
NEXUS_DB_ACTIVE=

# ── Server ────────────────────────────────────────────────────────────────────
NEXUS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXUS_RATE_LIMIT=60

# ── Storage Paths ─────────────────────────────────────────────────────────────
NEXUS_KB_DIR=./nexus_kb
NEXUS_AUTH_DB=./nexus_auth.db

# ── REST API Key (optional) ───────────────────────────────────────────────────
NEXUS_API_KEY=
